    "steam-totp": "^2.1.2",
    "steam-tradeoffer-manager": "^2.12.1",
    "steam-user": "^5.2.3",
    "steamcommunity": "^3.48.8"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "@types/steam-totp": "^2.1.2",
