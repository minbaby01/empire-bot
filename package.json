{
  "name": "empire_bot",
  "version": "1.0.0",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx watch src/bot.ts",
    "check": "tsc --noEmit",
    "build": "rimraf dist && tsc",
    "start": "node dist/bot.js",
    "start:pm2": "npm run build && pm2 start dist/bot.js --name empire-bot",
